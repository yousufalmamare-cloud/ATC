<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ATC ↔ CNS Engineering | Daily Log System</title>
  <!-- Supabase JS Client -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: linear-gradient(145deg, #eef2fa 0%, #d9e2ef 100%);
      font-family: 'Inter', sans-serif;
      padding: 2rem 1.5rem;
      color: #1a2c3e;
    }
    .dashboard { max-width: 1440px; margin: 0 auto; }
    .aviation-header {
      background: rgba(10, 35, 55, 0.85);
      backdrop-filter: blur(12px);
      border-radius: 2rem;
      padding: 1.5rem 2rem;
      margin-bottom: 2rem;
      box-shadow: 0 12px 30px rgba(0,0,0,0.1);
    }
    .title-section {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: space-between;
    }
    .title-section h1 {
      font-size: 1.8rem;
      font-weight: 700;
      background: linear-gradient(135deg, #FFFFFF, #c0e0ff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      display: inline-flex;
      align-items: center;
      gap: 12px;
    }
    .title-section h1 i { background: none; color: #ffd966; }
    .badge-cns {
      background: #1f6392;
      padding: 0.5rem 1.2rem;
      border-radius: 60px;
      font-weight: 500;
      font-size: 0.85rem;
      color: white;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .subhead {
      color: #cfecff;
      margin-top: 12px;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .log-system-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 1.8rem;
    }
    .card {
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(2px);
      border-radius: 1.8rem;
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.2);
      padding: 1.6rem 1.8rem;
      border: 1px solid rgba(255,255,240,0.7);
      transition: transform 0.2s ease;
    }
    .card:hover { transform: translateY(-3px); }
    .card-header {
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 2px solid #e2edf7;
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
    }
    .card-header i {
      font-size: 1.8rem;
      color: #1e6f9f;
      background: #eef4fc;
      padding: 10px;
      border-radius: 18px;
    }
    .card-header h2 { font-weight: 600; font-size: 1.5rem; color: #0a3b4f; }
    .form-group { margin-bottom: 1.2rem; display: flex; flex-direction: column; }
    label {
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #2c5778;
      margin-bottom: 0.4rem;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    input, select, textarea {
      font-family: 'Inter', monospace;
      background: #f9fbfd;
      border: 1px solid #cbdbe2;
      border-radius: 1rem;
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
      transition: all 0.2s;
      outline: none;
    }
    input:focus, select:focus, textarea:focus {
      border-color: #2c7cb6;
      box-shadow: 0 0 0 3px rgba(44,124,182,0.2);
      background: white;
    }
    textarea { resize: vertical; min-height: 85px; }
    .row-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
    .btn-primary {
      background: linear-gradient(105deg, #166f9c, #0f4e70);
      border: none;
      color: white;
      font-weight: 700;
      padding: 0.9rem 1.2rem;
      border-radius: 2rem;
      width: 100%;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
      margin-top: 0.8rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    .btn-primary:hover { background: linear-gradient(105deg, #1b84b8, #12638b); transform: scale(1.01); }
    .logs-feed { max-height: 560px; overflow-y: auto; padding-right: 6px; }
    .log-entry {
      background: white;
      border-radius: 1.2rem;
      padding: 1rem;
      margin-bottom: 1rem;
      border-left: 5px solid;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .log-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }
    .log-title {
      font-weight: 700;
      font-size: 1rem;
      color: #0b3b4f;
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }
    .status-badge {
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.2rem 0.7rem;
      border-radius: 40px;
    }
    .status-Operational { background: #d4edda; color: #155724; border-left-color: #2b8c4a; }
    .status-Degraded { background: #fff3cd; color: #856404; border-left-color: #e0a800; }
    .status-Outage { background: #f8d7da; color: #721c24; border-left-color: #c82333; }
    .status-Maintenance { background: #d1ecf1; color: #0c5460; border-left-color: #17a2b8; }
    .status-Testing { background: #e2e3e5; color: #383d41; border-left-color: #6c757d; }
    .log-meta { font-size: 0.7rem; color: #5d7f96; display: flex; flex-wrap: wrap; gap: 12px; margin: 6px 0; }
    .log-desc { font-size: 0.85rem; color: #2c3e4e; margin: 8px 0; line-height: 1.4; }
    .resolution-box {
      background: #e8f4e8;
      border-radius: 1rem;
      padding: 0.6rem 0.9rem;
      margin-top: 12px;
      font-size: 0.8rem;
      border-left: 3px solid #2c8c4a;
      display: flex;
      gap: 10px;
      align-items: flex-start;
    }
    .action-buttons { display: flex; gap: 8px; margin-top: 10px; justify-content: flex-end; }
    .resolve-btn, .delete-log {
      background: transparent;
      border: 1px solid #cbdbe2;
      padding: 0.3rem 0.8rem;
      border-radius: 2rem;
      font-size: 0.7rem;
      font-weight: 500;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .resolve-btn { background: #eef4fc; color: #1e6f9f; border-color: #bdd4e8; }
    .resolve-btn:hover { background: #cfe3ff; }
    .delete-log { background: #fff5f5; color: #b91c1c; border-color: #f5c6cb; }
    .delete-log:hover { background: #ffe0e0; }
    .resolved-badge {
      background: #2b8c4a;
      color: white;
      font-size: 0.7rem;
      padding: 0.2rem 0.7rem;
      border-radius: 40px;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .clear-all-btn, .refresh-btn {
      background: rgba(0,0,0,0.05);
      border: 1px solid #cbd5e1;
      padding: 0.5rem 1rem;
      border-radius: 2rem;
      font-size: 0.75rem;
      font-weight: 500;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .clear-all-btn:hover { background: #e9ecef; color: #b91c1c; border-color: #f5c6cb; }
    .refresh-btn:hover { background: #e9ecef; color: #1f6392; }
    .toast-msg {
      position: fixed;
      bottom: 24px;
      right: 24px;
      background: #1f5e3c;
      color: white;
      padding: 12px 22px;
      border-radius: 60px;
      font-weight: 500;
      z-index: 1000;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .footer-note {
      margin-top: 2rem;
      text-align: center;
      font-size: 0.75rem;
      color: #4a6c86;
      background: rgba(255,255,240,0.5);
      border-radius: 40px;
      padding: 0.6rem;
      width: fit-content;
      margin: 1.5rem auto 0;
    }
    @media (max-width: 850px) {
      .log-system-grid { grid-template-columns: 1fr; }
      body { padding: 1rem; }
    }
  </style>
</head>
<body>
<div class="dashboard">
  <div class="aviation-header">
    <div class="title-section">
      <h1><i class="fas fa-tower-broadcast"></i> ATC DAILY LOG ↔ CNS ENGINEERING</h1>
      <div class="badge-cns"><i class="fas fa-microchip"></i> Resolve & Relay</div>
    </div>
    <div class="subhead">
      <i class="fas fa-paper-plane"></i> ATC sends status → CNS resolves → “Solved by” appears
    </div>
  </div>

  <div class="log-system-grid">
    <!-- ATC Form -->
    <div class="card">
      <div class="card-header">
        <i class="fas fa-user-astronaut"></i>
        <h2>ATC Log Transmitter</h2>
      </div>
      <form id="dailyLogForm">
        <div class="row-2col">
          <div class="form-group">
            <label><i class="far fa-calendar-alt"></i> Date *</label>
            <input type="date" id="logDate" required>
          </div>
          <div class="form-group">
            <label><i class="fas fa-clock"></i> Shift *</label>
            <select id="shiftSelect">
              <option>Morning (0600-1400)</option>
              <option>Afternoon (1400-2200)</option>
              <option>Night (2200-0600)</option>
            </select>
          </div>
        </div>
        <div class="row-2col">
          <div class="form-group">
            <label><i class="fas fa-satellite-dish"></i> CNS Component *</label>
            <select id="cnsComponent">
              <option>COM (Communication)</option>
              <option>NAV (Navigation)</option>
              <option>SUR (Surveillance)</option>
              <option>General / Other</option>
            </select>
          </div>
          <div class="form-group">
            <label><i class="fas fa-chart-line"></i> Status Type *</label>
            <select id="statusType">
              <option>Operational</option>
              <option>Degraded</option>
              <option>Outage</option>
              <option>Maintenance</option>
              <option>Testing</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label><i class="fas fa-heading"></i> Log Title *</label>
          <input type="text" id="logTitle" placeholder="e.g., ILS Glidepath fluctuation" required>
        </div>
        <div class="form-group">
          <label><i class="fas fa-align-left"></i> Detailed Description *</label>
          <textarea id="logDesc" placeholder="Describe anomaly, impact, or current status..." required></textarea>
        </div>
        <div class="form-group">
          <label><i class="fas fa-id-badge"></i> ATC User (Name/Call sign)</label>
          <input type="text" id="atcUser" placeholder="e.g., J. Smith / TWR_CTL">
        </div>
        <button type="submit" class="btn-primary"><i class="fas fa-share-square"></i> SEND DAILY LOG TO CNS ENGINEERING</button>
      </form>
    </div>

    <!-- CNS Inbox -->
    <div class="card">
      <div class="card-header">
        <i class="fas fa-microscope"></i>
        <h2>CNS Engineering Inbox</h2>
        <div style="flex:1"></div>
        <button id="refreshInboxBtn" class="refresh-btn"><i class="fas fa-sync-alt"></i> Refresh</button>
        <button id="clearAllLogsBtn" class="clear-all-btn"><i class="fas fa-trash-alt"></i> Clear all</button>
      </div>
      <div id="logsContainer" class="logs-feed">
        <div class="empty-logs"><i class="fas fa-inbox"></i> Loading logs...</div>
      </div>
      <div style="margin-top: 12px; border-top: 1px dashed #cbdbe2; padding-top: 12px; font-size: 12px; color: #346f8c; text-align: center;">
        <i class="fas fa-reply-all"></i> CNS: click "Resolve" to mark issue solved & tell ATC who fixed it
      </div>
    </div>
  </div>
  <div class="footer-note">
    <i class="fas fa-database"></i> Data stored securely in Supabase. All users see the same logs in real‑time.
  </div>
</div>

<script>
  // ==================== CONFIGURE SUPABASE ====================
  const SUPABASE_URL = 'https://zqjmgfgftblzifsiipkj.supabase.co';  // <-- REPLACE WITH YOUR URL
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inpxam1nZmdmdGJsemlmc2lpcGtqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4NDkyOTYsImV4cCI6MjA5MDQyNTI5Nn0.fF-5WSSF9V64bOpfzzDhh-3BVVSqyMKJWjlhwoLUskI';              // <-- REPLACE WITH YOUR ANON KEY
  const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  // Helper to show toast notifications
  function showToast(message, bgColor = "#1f5e3c") {
    const existing = document.querySelector('.toast-msg');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = 'toast-msg';
    toast.style.backgroundColor = bgColor;
    toast.innerHTML = `<i class="fas fa-info-circle"></i> ${message}`;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3300);
  }

  // Escape HTML for safety
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // Render logs from Supabase data
  function renderLogs(logs) {
    const container = document.getElementById('logsContainer');
    if (!container) return;

    if (!logs || logs.length === 0) {
      container.innerHTML = `<div class="empty-logs"><i class="fas fa-paper-plane"></i> No logs yet. Send one from ATC.</div>`;
      return;
    }

    // Sort newest first
    const sorted = [...logs].sort((a,b) => new Date(b.created_at) - new Date(a.created_at));
    let html = '';
    for (const log of sorted) {
      let statusClass = 'status-Operational';
      if (log.status_type === 'Degraded') statusClass = 'status-Degraded';
      else if (log.status_type === 'Outage') statusClass = 'status-Outage';
      else if (log.status_type === 'Maintenance') statusClass = 'status-Maintenance';
      else if (log.status_type === 'Testing') statusClass = 'status-Testing';

      const isResolved = log.resolved === true;
      html += `
        <div class="log-entry ${statusClass}" style="border-left-color: inherit;">
          <div class="log-header">
            <div class="log-title">
              <i class="fas fa-clipboard-list"></i> ${escapeHtml(log.title)}
              <span class="status-badge ${statusClass.replace('status-', '')}">${escapeHtml(log.status_type)}</span>
              ${isResolved ? '<span class="resolved-badge"><i class="fas fa-check-circle"></i> RESOLVED</span>' : ''}
            </div>
            <button class="delete-log" data-id="${log.id}" title="Remove log"><i class="fas fa-times-circle"></i> Delete</button>
          </div>
          <div class="log-meta">
            <span><i class="far fa-calendar-check"></i> ${escapeHtml(log.log_date)} · ${escapeHtml(log.shift)}</span>
            <span><i class="fas fa-microchip"></i> ${escapeHtml(log.component)}</span>
            <span><i class="fas fa-user-check"></i> ATC: ${escapeHtml(log.atc_user_name || 'Operator')}</span>
          </div>
          <div class="log-meta">
            <span><i class="fas fa-cloud-upload-alt"></i> Received: ${new Date(log.created_at).toLocaleString()}</span>
          </div>
          <div class="log-desc">
            <strong>${escapeHtml(log.title)}</strong><br>
            ${escapeHtml(log.description)}
          </div>
      `;

      if (isResolved) {
        html += `
          <div class="resolution-box">
            <i class="fas fa-check-double"></i>
            <div style="flex:1">
              <strong>✓ RESOLVED & relayed to ATC</strong><br>
              <span>Solved by: ${escapeHtml(log.resolved_by)}</span><br>
              <span style="font-size:0.7rem;">Resolution: ${new Date(log.resolved_at).toLocaleString()}</span>
              ${log.resolution_note ? `<div style="margin-top:4px;">📝 ${escapeHtml(log.resolution_note)}</div>` : ''}
            </div>
          </div>
        `;
      } else {
        html += `
          <div class="action-buttons">
            <button class="resolve-btn" data-id="${log.id}"><i class="fas fa-wrench"></i> Resolve issue → Relay to ATC</button>
          </div>
        `;
      }
      html += `</div>`;
    }
    container.innerHTML = html;

    // Attach event listeners
    document.querySelectorAll('.delete-log').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.getAttribute('data-id');
        if (id && confirm("Delete this log from CNS inbox?")) {
          deleteLogById(id);
        }
      });
    });

    document.querySelectorAll('.resolve-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.getAttribute('data-id');
        if (id) resolveLogById(id);
      });
    });
  }

  // Fetch all logs from Supabase
  async function fetchLogs() {
    try {
      const { data, error } = await supabase
        .from('daily_logs')
        .select('*')
        .order('created_at', { ascending: false });
      if (error) throw error;
      renderLogs(data || []);
    } catch (err) {
      console.error('Error fetching logs:', err);
      showToast('Failed to load logs. Check console.', '#b4433c');
    }
  }

  // Delete a log (only admin-like; you may want to restrict in real app)
  async function deleteLogById(id) {
    try {
      const { error } = await supabase
        .from('daily_logs')
        .delete()
        .eq('id', id);
      if (error) throw error;
      showToast('Log deleted', '#7a5a5a');
      fetchLogs(); // refresh
    } catch (err) {
      console.error('Delete error:', err);
      showToast('Delete failed: ' + err.message, '#b4433c');
    }
  }

  // Resolve a log: update with resolved_by, resolved_at, resolution_note, resolved = true
  async function resolveLogById(id) {
    const solver = prompt("✈️ CNS Engineering: Enter name of the person who solved this problem:", "CNS Engineer");
    if (!solver || solver.trim() === "") { showToast("Resolution cancelled – solver name required", "#b4433c"); return; }
    const note = prompt("Optional: Add a short resolution note (e.g., 'Replaced antenna'):", "Problem solved and verified");
    
    try {
      const { error } = await supabase
        .from('daily_logs')
        .update({
          resolved: true,
          resolved_by: solver.trim(),
          resolved_at: new Date().toISOString(),
          resolution_note: (note && note.trim()) ? note.trim() : "Issue resolved by CNS Engineering"
        })
        .eq('id', id);
      if (error) throw error;
      showToast(`✅ Resolved & relayed to ATC: solved by ${solver.trim()}`, "#1f6e43");
      fetchLogs(); // refresh
    } catch (err) {
      console.error('Resolve error:', err);
      showToast('Failed to resolve: ' + err.message, '#b4433c');
    }
  }

  // Submit new log from ATC
  async function addNewLog(event) {
    event.preventDefault();

    const logDate = document.getElementById('logDate').value;
    const shift = document.getElementById('shiftSelect').value;
    const component = document.getElementById('cnsComponent').value;
    const statusType = document.getElementById('statusType').value;
    const title = document.getElementById('logTitle').value.trim();
    const description = document.getElementById('logDesc').value.trim();
    const atcUser = document.getElementById('atcUser').value.trim();

    if (!logDate) { showToast("Please select a date", "#b4433c"); return; }
    if (!title) { showToast("Log Title required", "#b4433c"); return; }
    if (!description) { showToast("Description required", "#b4433c"); return; }

    const newLog = {
      log_date: logDate,
      shift: shift,
      component: component,
      status_type: statusType,
      title: title,
      description: description,
      atc_user_name: atcUser || "ATC Operator",
      created_at: new Date().toISOString(),
      resolved: false,
      resolved_by: null,
      resolved_at: null,
      resolution_note: null
    };

    try {
      const { error } = await supabase
        .from('daily_logs')
        .insert([newLog]);
      if (error) throw error;
      showToast(`✈️ Log "${title.substring(0, 45)}" sent to CNS engineering`, "#1f6e43");
      
      // Reset form
      document.getElementById('logTitle').value = '';
      document.getElementById('logDesc').value = '';
      document.getElementById('atcUser').value = '';
      document.getElementById('logDate').value = new Date().toISOString().split('T')[0];
      document.getElementById('shiftSelect').value = "Morning (0600-1400)";
      document.getElementById('cnsComponent').value = "COM (Communication)";
      document.getElementById('statusType').value = "Operational";
      
      fetchLogs(); // refresh inbox
    } catch (err) {
      console.error('Insert error:', err);
      showToast('Failed to send log: ' + err.message, '#b4433c');
    }
  }

  // Clear all logs (dangerous, but for demo)
  async function clearAllLogs() {
    if (!confirm("⚠️ PERMANENT: Delete ALL logs? This cannot be undone.")) return;
    try {
      const { error } = await supabase
        .from('daily_logs')
        .delete()
        .neq('id', 0); // deletes all rows
      if (error) throw error;
      showToast("All logs cleared", "#2c6e8f");
      fetchLogs();
    } catch (err) {
      console.error('Clear all error:', err);
      showToast('Failed to clear logs: ' + err.message, '#b4433c');
    }
  }

  // Set default date to today
  function setDefaultDate() {
    const today = new Date().toISOString().split('T')[0];
    const dateInput = document.getElementById('logDate');
    if (dateInput) dateInput.value = today;
  }

  // Initialization
  document.addEventListener('DOMContentLoaded', () => {
    setDefaultDate();
    fetchLogs();

    const form = document.getElementById('dailyLogForm');
    form.addEventListener('submit', addNewLog);

    document.getElementById('clearAllLogsBtn').addEventListener('click', clearAllLogs);
    document.getElementById('refreshInboxBtn').addEventListener('click', () => {
      fetchLogs();
      showToast("Inbox refreshed", "#1f6392");
    });
  });
</script>
</body>
</html>
